PORT=3001

# ------- BLING API v3 -------
# Obtenha em: https://developer.bling.com.br/aplicativos
BLING_CLIENT_ID=SEU_CLIENT_ID_AQUI
BLING_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI

# Após a autenticação OAuth, cole o access_token aqui (ou use o fluxo OAuth completo)
BLING_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI
BLING_REFRESH_TOKEN=SEU_REFRESH_TOKEN_AQUI

# Configurações de produção
NODE_ENV=development
