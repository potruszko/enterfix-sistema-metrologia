PORT=3001

# ------- BLING API v3 -------
# Obtenha em: https://developer.bling.com.br/aplicativos
BLING_CLIENT_ID=SEU_CLIENT_ID_AQUI
BLING_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI

# Após a autenticação OAuth, cole o access_token aqui (ou use o fluxo OAuth completo)
BLING_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI
BLING_REFRESH_TOKEN=SEU_REFRESH_TOKEN_AQUI

# Configurações de produção
NODE_ENV=development

# URL pública do backend (Railway em produção, vazio em dev usa localhost automático)
# Exemplo: https://meu-backend.railway.app
BACKEND_URL=

# URL pública do frontend (Vercel em produção, vazio em dev usa localhost:5173)
# Exemplo: https://meu-app.vercel.app
FRONTEND_URL=

# ------- Supabase (MES) -------
DATABASE_URL=postgresql://postgres:SENHA@db.xxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
