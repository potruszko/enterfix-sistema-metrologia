{
  "name": "enterfix-comodato-system",
  "version": "1.0.0",
  "description": "Sistema profissional de geração de contratos de comodato - Enterfix Metrologia",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "client": "cd client && npm start",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "keywords": [
    "comodato",
    "contratos",
    "metrologia",
    "enterfix"
  ],
  "author": "Enterfix Metrologia",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "puppeteer": "^21.6.1",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}
